class Solution {
public:
    bool isAnagram(string s, string t) {

        //----------HASHING_____

        
        // sort(s.begin(),s.end());
        // sort(t.begin(),t.end());
        // return s ==t ;
        vector<int>f(26);
        for ( char ch : s){
            f[ch-'a']++;

        }
            for ( char ch : t){
            f[ch-'a']--;

        }
        for ( int i = 0; i <26;i++){
            if (f[i] != 0){
                return false;
            }
        }
        return true;
    }
};
