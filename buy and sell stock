class Solution {
public:
    int maxProfit(vector<int>& prices) {
        int n = prices.size();
        int maxprofit = 0;
        for (int buy = 0;buy<n;buy++){
            int profit = 0;
            for (int sell = buy ;sell<n;sell++){
                profit = prices[sell] - prices[buy];
                if(profit>maxprofit){
                    maxprofit = profit;
                }
            }
        }
        return maxprofit;
    }
};
